# Use UBI 9 Python 3.11 as the base
FROM registry.redhat.io/ubi9/python-311

# Switch to root to install system dependencies
USER 0

#COPY files/classroom-ca.pem /etc/pki/ca-trust/source/anchors/
#
#RUN update-ca-trust

RUN mkdir -p /tmp/ansible /tmp/pre-commit-cache /tmp/cache && \
    chmod -R 777 /tmp/ansible /tmp/pre-commit-cache /tmp/cache

# Update packages and install git (required by pre-commit)
RUN dnf -y install https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm --nogpgcheck && \
    dnf -y update && \
    dnf -y install git rubygem-asciidoctor && \
    dnf clean all

# Switch back to the default non-root user provided by the UBI image
USER 1001

# Install pre-commit, ansible-lint, and yamllint via pip
# We use --no-cache-dir to keep the image size small
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
    pre-commit \
    ansible-lint \
    yamllint

# Set the working directory
WORKDIR /src

# Set the default command to show versions (verifies installation)
CMD ["pre-commit", "--version"]
